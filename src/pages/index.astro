---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Ryan Chibana">
  <section class="hero">
    <h1>Hey, I'm Ryan.</h1>
    <p>
      I build things on the web and explore ideas through data visualization and creative coding.
      This site is where I share what I'm working on.
    </p>
  </section>

  {posts.length > 0 && (
    <section class="recent-posts">
      <h2>Recent Posts</h2>
      {posts.map((post) => (
        <PostCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
        />
      ))}
      <p class="all-link">
        <a href="/blog">All posts &rarr;</a>
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .recent-posts h2 {
    margin-bottom: 0.5rem;
  }

  .all-link {
    margin-top: 1rem;
  }
</style>
