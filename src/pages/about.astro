---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Ryan Chibana" description="About Ryan Chibana">
  <h1>About</h1>
  <p>
    I'm Ryan Chibana. I'm interested in web development, data visualization, and creative coding.
  </p>
  <p>
    This site is built with <a href="https://astro.build">Astro</a>, using D3.js for data
    visualizations and Three.js for 3D scenes. It ships zero JavaScript on static pages and
    lazy-loads interactive components only when needed.
  </p>
</BaseLayout>
