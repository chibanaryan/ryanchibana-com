---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://github.com/chibanaryan', label: 'GitHub' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav>
    <a href="/" class="site-title">Ryan Chibana</a>
    <ul>
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} {...(href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})} class:list={[{ active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}>
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .site-title:hover {
    text-decoration: none;
    color: var(--color-accent);
  }

  ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
  }

  ul a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  ul a:hover,
  ul a.active {
    color: var(--color-accent);
  }
</style>
