---
interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { id, title, description, pubDate, tags = [] } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${id}`}>
    <h3>{title}</h3>
  </a>
  <time datetime={pubDate.toISOString()}>{dateStr}</time>
  <p>{description}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  h3 {
    margin-bottom: 0.25rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  p {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    background: rgba(184, 90, 58, 0.08);
    color: var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
</style>
