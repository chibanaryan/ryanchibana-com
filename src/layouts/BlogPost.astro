---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: Heading[];
}

const { title, description, pubDate, updatedDate, tags = [], headings = [] } = Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const showToc = headings.filter((h) => h.depth <= 3).length > 2;
---

<BaseLayout title={title} description={description}>
  <div class:list={['post-layout', { 'has-toc': showToc }]}>
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="meta">
          <time datetime={pubDate.toISOString()}>{dateStr}</time>
          {updatedDate && (
            <span>
              (Updated: {updatedDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })})
            </span>
          )}
        </div>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
    {showToc && (
      <aside class="toc-sidebar">
        <TableOfContents headings={headings} title={title} />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .post-layout {
    position: relative;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .meta {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    background: rgba(184, 90, 58, 0.08);
    color: var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .prose :global(h2) {
    margin-top: 2rem;
  }

  .prose :global(a) {
    text-decoration: underline;
  }

  .toc-sidebar {
    display: none;
  }

  @media (min-width: 80rem) {
    .post-layout.has-toc {
      display: grid;
      grid-template-columns: 1fr 10rem;
      gap: 2rem;
      margin-left: -6rem;
      margin-right: -6rem;
    }

    .toc-sidebar {
      display: block;
    }
  }
</style>
